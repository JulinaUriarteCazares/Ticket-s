# Opcion 1 (recomendada para esta red): URL pooler de Supabase (IPv4)
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Opcion 2: variables separadas (si no usas DATABASE_URL)
DB_HOST=aws-0-us-west-2.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.<PROJECT_REF>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=postgres

JWT_SECRET=cambia_esta_clave_por_una_segura
PORT=3000
